{
  "name": "codeguardian-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "jest --testEnvironment jsdom",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "axios": "1.13.5",
    "clsx": "2.1.0",
    "next": "15.5.12",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "recharts": "2.12.2"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@testing-library/jest-dom": "6.4.2",
    "@testing-library/react": "14.2.1",
    "@types/jest": "29.5.12",
    "@types/node": "20.11.16",
    "@types/react": "18.2.55",
    "@types/react-dom": "18.2.19",
    "autoprefixer": "10.4.17",
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "postcss": "8.4.35",
    "tailwindcss": "3.4.1",
    "ts-jest": "29.1.2",
    "typescript": "5.3.3"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "transform": {
      "^.+\\.(ts|tsx)$": [
        "ts-jest",
        {
          "tsconfig": {
            "jsx": "react"
          }
        }
      ]
    },
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    },
    "setupFilesAfterEnv": [
      "@testing-library/jest-dom"
    ],
    "testMatch": [
      "**/__tests__/**/*.(test|spec).(ts|tsx)"
    ]
  }
}
